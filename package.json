{
  "name": "nebula",
  "version": "3.0.1",
  "description": "Manage multiple Valorant accounts easily.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:renderer": "cd renderer && npm run build",
    "build": "npm run build:renderer && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "valorant",
    "account",
    "manager",
    "electron"
  ],
  "author": "v1niii",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "node-fetch": "^2.6.7",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.6.3"
  },
  "build": {
    "appId": "com.v1niii.nebula",
    "productName": "Nebula",
    "publish": [
      {
        "provider": "github",
        "owner": "v1niii",
        "repo": "Nebula"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "auth-service.js",
      "auth-launch-service.js",
      "renderer/dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets"
    }
  }
}
